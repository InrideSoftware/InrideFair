<Window x:Class="InrideFair.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Inride Fair"
        Height="880" Width="1300"
        MinHeight="700" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1a0f2e" Offset="0"/>
            <GradientStop Color="#2d1f4e" Offset="0.5"/>
            <GradientStop Color="#4a1f3f" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="-1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0f051a"
                Height="30"
                VerticalAlignment="Top"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="🛡️" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                              FontSize="13"
                              FontWeight="SemiBold"
                              Foreground="#c084fc"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="─"
                            Width="45" Height="30"
                            Background="Transparent"
                            Foreground="#a0a0b0"
                            BorderThickness="0"
                            FontSize="16"
                            Cursor="Hand"
                            Click="MinimizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2a2a4a"/>
                                                    <Setter Property="Foreground" Value="#ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="□"
                            Width="45" Height="30"
                            Background="Transparent"
                            Foreground="#a0a0b0"
                            BorderThickness="0"
                            FontSize="12"
                            Cursor="Hand"
                            Click="MaximizeButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2a2a4a"/>
                                                    <Setter Property="Foreground" Value="#ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="✕"
                            Width="45" Height="30"
                            Background="Transparent"
                            Foreground="#a0a0b0"
                            BorderThickness="0"
                            FontSize="14"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#e81123"/>
                                                    <Setter Property="Foreground" Value="#ffffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Sidebar Menu -->
        <Border Grid.Column="0" Background="#1a0f2e" BorderBrush="#3a2a5a" BorderThickness="0,0,1,0" Margin="0,30,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App Logo & Title -->
                <Border Grid.Row="0" Padding="20,25,20,20" Background="#2d1f4e">
                    <StackPanel>
                        <TextBlock Text="🛡️" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Inride Fair"
                                  FontSize="20"
                                  FontWeight="Bold"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  Margin="0,8,0,3"/>
                        <TextBlock x:Name="VersionTextBlock"
                                  FontSize="11"
                                  Foreground="#a0a0b0"
                                  HorizontalAlignment="Center"/>
                        <Border Background="#3a2a5a"
                                CornerRadius="4"
                                Padding="8,6"
                                Margin="0,10,0,0">
                            <TextBlock Text="Anti-Cheat Scanner"
                                      FontSize="10"
                                      Foreground="#c084fc"
                                      HorizontalAlignment="Center"
                                      FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Margin="12,20,12,0">
                    <TextBlock x:Name="MenuHeaderText" Text="МЕНЮ"
                              FontSize="11"
                              FontWeight="Bold"
                              Foreground="#6a6a80"
                              Margin="0,0,0,15"
                              HorizontalAlignment="Center"/>

                    <Button x:Name="HomeButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Tag="True"
                            Click="MenuButton_Click"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🏠" FontSize="18" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text=" Главная" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="AboutButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="ℹ️" FontSize="18" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text=" О программе" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="QnAButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="❓" FontSize="18" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text=" Вопросы и ответы" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="DeveloperButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="👨‍💻" FontSize="18" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text=" О разработчике" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="GitHubButton"
                            Style="{StaticResource MenuButtonStyle}"
                            Click="MenuButton_Click"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🐦" FontSize="18" Width="24" HorizontalAlignment="Center"/>
                            <TextBlock Text=" GitHub" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="20" Background="#2d1f4e">
                    <StackPanel>
                        <TextBlock Text="© 2026 Inride Software"
                                  FontSize="10"
                                  Foreground="#6a6a80"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Все права защищены"
                                  FontSize="9"
                                  Foreground="#5a5a70"
                                  HorizontalAlignment="Center"
                                  Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="30,60,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Home View -->
            <Grid x:Name="HomeView">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Сканирование системы" Style="{StaticResource TitleStyle}"/>
                        <TextBlock Text="Проверка на наличие читов и вредоносного ПО" Style="{StaticResource SubtitleStyle}" Margin="0,8,0,15"/>
                        
                        <Border Background="{StaticResource CardBackground}" CornerRadius="10" Padding="15,10" HorizontalAlignment="Left" MaxWidth="500">
                            <TextBlock x:Name="SystemInfoText"
                                      Style="{StaticResource SubtitleStyle}"
                                      VerticalAlignment="Center"
                                      TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Status Bar -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" 
                                x:Name="StatusIndicator"
                                Width="16" Height="16" 
                                CornerRadius="8" 
                                Background="{StaticResource InfoColor}"
                                Margin="0,0,15,0"/>
                        
                        <StackPanel Grid.Row="0" Grid.Column="1">
                            <TextBlock x:Name="StatusLabel" 
                                      Text="● Готов к проверке" 
                                      FontSize="16" 
                                      FontWeight="SemiBold"
                                      Foreground="{StaticResource PrimaryText}"/>
                            <TextBlock x:Name="ProgressLabel" 
                                      Text="Ожидание запуска..." 
                                      FontSize="12" 
                                      Foreground="{StaticResource TertiaryText}"
                                      Margin="0,5,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="0" Grid.Column="2" 
                                x:Name="StatusBadge"
                                Background="{StaticResource CardBackground}" 
                                CornerRadius="20" 
                                Padding="20,10"
                                BorderBrush="#3a3a5a"
                                BorderThickness="1">
                            <TextBlock Text="ОЖИДАНИЕ" 
                                      FontSize="12" 
                                      FontWeight="Bold"
                                      Foreground="{StaticResource SecondaryText}"
                                      VerticalAlignment="Center"/>
                        </Border>

                        <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                    x:Name="ProgressBar"
                                    Style="{StaticResource ModernProgressBarStyle}"
                                    Margin="0,20,0,0"/>
                    </Grid>
                </Border>

                <!-- Summary Cards -->
                <Grid Grid.Row="2" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <TextBlock Text="ВСЕГО" FontSize="11" Foreground="{StaticResource TertiaryText}" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TotalCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#3a1a2a" CornerRadius="12" Padding="20" Margin="10,0">
                        <StackPanel>
                            <TextBlock Text="ВЫСОКИЙ РИСК" FontSize="11" Foreground="#f472b6" FontWeight="SemiBold"/>
                            <TextBlock x:Name="HighRiskCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#f472b6" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#3a2a1a" CornerRadius="12" Padding="20" Margin="10,0">
                        <StackPanel>
                            <TextBlock Text="СРЕДНИЙ РИСК" FontSize="11" Foreground="#fbbf24" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MediumRiskCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#fbbf24" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Background="#1a3a2a" CornerRadius="12" Padding="20" Margin="10,0">
                        <StackPanel>
                            <TextBlock Text="НИЗКИЙ РИСК" FontSize="11" Foreground="#34d399" FontWeight="SemiBold"/>
                            <TextBlock x:Name="LowRiskCount" Text="0" FontSize="36" FontWeight="Bold" Foreground="#34d399" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Details & Log Section (Side by Side) -->
                <Grid Grid.Row="3" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Details Section -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,7,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📊 Детали сканирования" Style="{StaticResource SectionTitleStyle}"/>

                            <TextBox Grid.Row="1" x:Name="DetailsText" 
                                    Style="{StaticResource LogTextBoxStyle}"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Top"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    TextAlignment="Left">
                                <TextBox.Text>
  • Процессы: 0
  • Файлы: 0
  • Архивы: 0
  • Браузеры: 0
  • Реестр: 0
                                </TextBox.Text>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Log Section -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="7,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📋 Журнал событий" Style="{StaticResource SectionTitleStyle}"/>

                            <TextBox Grid.Row="1" x:Name="LogText" 
                                    Style="{StaticResource LogTextBoxStyle}"
                                    VerticalAlignment="Stretch"
                                    VerticalContentAlignment="Top"
                                    TextWrapping="Wrap"
                                    AcceptsReturn="True"
                                    TextAlignment="Left">
                                <TextBox.Text>Ожидание запуска проверки...
                                </TextBox.Text>
                            </TextBox>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,30">
                    <Button x:Name="ScanButton"
                            Content="🔍 НАЧАТЬ ПРОВЕРКУ"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="280"
                            Click="ScanButton_Click"/>
                </StackPanel>

                <!-- Secondary Buttons -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="OpenFolderButton"
                            Content="📂 Открыть папки"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="160"
                            Margin="0,0,15,0"
                            IsEnabled="False"
                            Click="OpenFolderButton_Click"/>

                    <Button x:Name="OpenReportButton"
                            Content="📄 Открыть отчёт"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="160"
                            IsEnabled="False"
                            Click="OpenReportButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- About View -->
            <Grid x:Name="AboutView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="О программе" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                            <Border Height="2" Background="#3a2a5a" Margin="0,10,0,30"/>

                            <TextBlock Text="Inride Fair — система обнаружения читов"
                                      FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>

                            <TextBlock x:Name="AboutDescriptionText"
                                      FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="22"/>
                            
                            <TextBlock Text="Возможности:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>
                            <StackPanel Margin="20,0,0,20">
                                <TextBlock Text="• Анализ запущенных процессов" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Проверка файлов на наличие сигнатур читов" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Сканирование архивов" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Анализ истории браузеров" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Проверка реестра Windows" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Генерация подробных отчётов в HTML и JSON" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                            </StackPanel>
                            
                            <TextBlock Text="Техническая информация:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>
                            <Border Background="#2d1f4e" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TertiaryText}">Версия:</Run> 1.0.0
                                    </TextBlock>
                                    <TextBlock FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TertiaryText}">Платформа:</Run> .NET 11.0
                                    </TextBlock>
                                    <TextBlock FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TertiaryText}">Технология:</Run> WPF (Windows Presentation Foundation)
                                    </TextBlock>
                                    <TextBlock FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5">
                                        <Run FontWeight="SemiBold" Foreground="{StaticResource TertiaryText}">Лицензия:</Run> Proprietary
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            
                            <TextBlock Text="© 2026 Inride Software. Все права защищены." 
                                      FontSize="12" Foreground="{StaticResource TertiaryText}" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- QnA View -->
            <Grid x:Name="QnAView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="Вопросы и ответы" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                            <Border Height="2" Background="#3a2a5a" Margin="0,10,0,30"/>
                            
                            <!-- Q1 -->
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="❓ Что такое Inride Fair?" 
                                              FontSize="16" FontWeight="SemiBold" Foreground="#c084fc" Margin="0,0,0,10"/>
                                    <TextBlock Text="Inride Fair — это утилита для обнаружения читов, вредоносного ПО и подозрительной активности в системе. Программа сканирует процессы, файлы, архивы, браузеры и реестр на наличие известных сигнатур читов." 
                                              FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Q2 -->
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="❓ Как работает сканирование?" 
                                              FontSize="16" FontWeight="SemiBold" Foreground="#c084fc" Margin="0,0,0,10"/>
                                    <TextBlock Text="Программа использует базу данных сигнатур известных читов и сравнивает их с файлами и процессами в системе. Также проводится эвристический анализ для выявления подозрительного поведения." 
                                              FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Q3 -->
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="❓ Безопасно ли использовать Inride Fair?" 
                                              FontSize="16" FontWeight="SemiBold" Foreground="#c084fc" Margin="0,0,0,10"/>
                                    <TextBlock Text="Да, программа полностью безопасна. Она не вносит изменений в систему, не удаляет файлы и не требует прав администратора для базовой функциональности." 
                                              FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Q4 -->
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="❓ Как часто обновляется база сигнатур?" 
                                              FontSize="16" FontWeight="SemiBold" Foreground="#c084fc" Margin="0,0,0,10"/>
                                    <TextBlock Text="База данных сигнатур обновляется с каждой версией программы. Рекомендуется регулярно обновлять Inride Fair для получения актуальных данных." 
                                              FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Q5 -->
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="❓ Что делать, если найдены угрозы?" 
                                              FontSize="16" FontWeight="SemiBold" Foreground="#c084fc" Margin="0,0,0,10"/>
                                    <TextBlock Text="После сканирования вы получите подробный отчёт со списком обнаруженных угроз. Используйте кнопку «Открыть папки» для перехода к файлам или удалите их вручную." 
                                              FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Developer View -->
            <Grid x:Name="DeveloperView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20">
                            <TextBlock Text="О разработчике" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                            <Border Height="2" Background="#3a2a5a" Margin="0,10,0,30"/>
                            
                            <StackPanel HorizontalAlignment="Center" Margin="0,0,0,30">
                                <Border Width="120" Height="120" CornerRadius="60" Background="#3a2a5a">
                                    <TextBlock Text="👨‍💻" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Inride Software" 
                                          FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" 
                                          HorizontalAlignment="Center" Margin="0,15,0,5"/>
                                <TextBlock Text="Software Developer" 
                                          FontSize="14" Foreground="{StaticResource TertiaryText}" 
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="О компании" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>
                            <TextBlock Text="Inride Software — независимая студия разработки программного обеспечения, специализирующаяся на создании утилит для безопасности и анализа систем." 
                                      FontSize="14" Foreground="{StaticResource SecondaryText}" TextWrapping="Wrap" Margin="0,0,0,20" LineHeight="22"/>
                            
                            <TextBlock Text="Направления деятельности:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>
                            <StackPanel Margin="20,0,0,20">
                                <TextBlock Text="• Разработка антивирусных решений" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Создание утилит для системного анализа" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Исследования в области кибербезопасности" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                                <TextBlock Text="• Консалтинг по вопросам безопасности" FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                            </StackPanel>
                            
                            <Border Background="#2d1f4e" CornerRadius="10" Padding="20" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="Контакты:" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryText}" Margin="0,0,0,15"/>
                                    <TextBlock FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,8">
                                        <Run FontWeight="SemiBold" Foreground="#c084fc">Email:</Run> contact@inride.software
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,8">
                                        <Run FontWeight="SemiBold" Foreground="#c084fc">Website:</Run> inride.software
                                    </TextBlock>
                                    <TextBlock FontSize="14" Foreground="{StaticResource SecondaryText}" Margin="0,8">
                                        <Run FontWeight="SemiBold" Foreground="#c084fc">Location:</Run> Worldwide
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            
                            <TextBlock Text="© 2026 Inride Software" 
                                      FontSize="12" Foreground="{StaticResource TertiaryText}" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- GitHub View -->
            <Grid x:Name="GitHubView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Grid.Row="0">
                    <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🐙" FontSize="80" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                        
                        <TextBlock Text="GitHub Repository" 
                                  FontSize="28" FontWeight="Bold" Foreground="{StaticResource PrimaryText}" 
                                  HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Исходный код проекта доступен на GitHub" 
                                  FontSize="16" Foreground="{StaticResource SecondaryText}" 
                                  HorizontalAlignment="Center" Margin="0,0,0,40"/>
                        
                        <Button x:Name="OpenGitHubButton"
                                Content="🚀 Перейти на GitHub"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Width="250"
                                Click="OpenGitHubButton_Click"/>
                        
                        <TextBlock Text="Здесь вы можете:" 
                                  FontSize="14" Foreground="{StaticResource TertiaryText}" 
                                  HorizontalAlignment="Center" Margin="0,30,0,15"/>
                        
                        <StackPanel>
                            <TextBlock Text="• Изучить исходный код" FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                            <TextBlock Text="• Сообщить об ошибках" FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                            <TextBlock Text="• Предложить улучшения" FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                            <TextBlock Text="• Следить за обновлениями" FontSize="13" Foreground="{StaticResource SecondaryText}" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
